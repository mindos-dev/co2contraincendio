# ═══════════════════════════════════════════════════════════════════════════════
# OPERIS Command Center — Modelo de Ambiente (.env.example)
# Copie este arquivo para .env e preencha os valores reais.
# Comando: cp .env.example .env
# ═══════════════════════════════════════════════════════════════════════════════

# ── Ambiente ──────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# ── Banco de Dados (MySQL) ────────────────────────────────────────────────────
DATABASE_URL=mysql://operis_user:SENHA_FORTE@db:3306/operis_db
MYSQL_ROOT_PASSWORD=ROOT_SENHA_FORTE
MYSQL_DATABASE=operis_db
MYSQL_USER=operis_user
MYSQL_PASSWORD=SENHA_FORTE

# ── Autenticação JWT (gere com: openssl rand -hex 32) ────────────────────────
JWT_SECRET=GERE_COM_openssl_rand_hex_32

# ── D.G.O. — Dashboard de Governança ─────────────────────────────────────────
DGO_JWT_SECRET=GERE_COM_openssl_rand_hex_32
DGO_ADMIN_USER=admin
DGO_ADMIN_PASS=SENHA_FORTE_DO_DGO
# Salt para hash de senhas do D.G.O. (gere com: openssl rand -hex 16)
DGO_SALT=GERE_COM_openssl_rand_hex_16

# ── Identificador da Aplicação ────────────────────────────────────────────────
VITE_APP_ID=GERE_COM_openssl_rand_hex_8

# ── OAuth / Forge ─────────────────────────────────────────────────────────────
OAUTH_SERVER_URL=
OWNER_OPEN_ID=
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=

# ── URL da Aplicação ──────────────────────────────────────────────────────────
APP_URL=https://seu-dominio.com

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_SUA_CHAVE_STRIPE
STRIPE_WEBHOOK_SECRET=whsec_SEU_WEBHOOK_SECRET

# ── Anthropic (opcional) ──────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-SUA_CHAVE_ANTHROPIC

# ── Ollama (IA Local) ─────────────────────────────────────────────────────────
OLLAMA_HOST=http://host-gateway:11434

# ── Busca Web (opcional) ──────────────────────────────────────────────────────
BRAVE_SEARCH_API_KEY=
SERPER_API_KEY=
TAVILY_API_KEY=

# ── SMTP ──────────────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu_email@gmail.com
SMTP_PASS=SUA_APP_PASSWORD
SMTP_FROM=OPERIS <seu_email@gmail.com>

# ── WhatsApp / Evolution API (opcional) ───────────────────────────────────────
EVOLUTION_API_URL=
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE=

# ── D.G.O. — Hardware do Host ─────────────────────────────────────────────────
# Execute no host: stat -c "%g" /var/run/docker.sock
DOCKER_GROUP_ID=127
DOCKER_SOCKET_PATH=/var/run/docker.sock
HOST_BACKUP_PATH=/host/backup
HOST_PROC_PATH=/host/proc
HOST_SYS_PATH=/host/sys

# ── AWS S3 (opcional) ─────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=SUA_ACCESS_KEY
AWS_SECRET_ACCESS_KEY=SUA_SECRET_KEY
AWS_REGION=sa-east-1
AWS_S3_BUCKET=operis-documentos
